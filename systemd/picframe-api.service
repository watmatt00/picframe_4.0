[Unit]
Description=PicFrame 4.0 API Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/picframe_4.0
Environment="PATH=%h/picframe_4.0/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=%h/picframe_4.0/venv/bin/python -m src.main
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
