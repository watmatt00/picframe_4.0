[Unit]
Description=PicFrame WiFi Watchdog
After=network.target
Wants=network.target

[Service]
Type=simple
# __PROJECT_DIR__ is substituted with the actual project path by install_setup.sh
ExecStart=__PROJECT_DIR__/scripts/setup/venv/bin/python3 __PROJECT_DIR__/scripts/setup/watchdog.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
